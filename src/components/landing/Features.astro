---
import features from '../../config/features.json'
---

<h1 class="text-center font-bold text-5xl mb-10">Features</h1>

<div class="grid md:grid-cols-3">
  {
    features.map((feature) => (
      <div class="bg-slate-800 p-10 rounded-xl h-auto m-2 hover:scale-102 transition-all duration-200 ease-in-out select-none">
        <h2 class="font-bold text-2xl mb-4">{feature.title}</h2>
        <p>
          {feature.description}
        </p>
      </div>
    ))
  }
</div>
